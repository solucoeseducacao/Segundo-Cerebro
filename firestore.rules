rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== USUÁRIOS =====
    match /usuarios/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Criação: usuário pode criar seu próprio documento
      allow create: if request.auth != null && request.auth.uid == userId;

      // Update: usuário pode atualizar apenas campos não sensíveis
      // Campos protegidos: somente o backend (Admin SDK) pode alterar
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny([
              'plano','planoExpira','creditos','adaptacoesDisponiveis','adaptacoesAvulsas',
              'isencaoAte','isencaoOrigem','assinaturaId','pagamentoId','creditosPromo','promoCode'
            ]);
    }

    // Subcoleções do usuário: citações, coleções, ideias, embeddings
    match /usuarios/{userId}/citacoes/{docId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }
    match /usuarios/{userId}/colecoes/{docId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }
    match /usuarios/{userId}/ideias/{docId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }
    match /usuarios/{userId}/embeddings/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ===== CÓDIGOS PROMOCIONAIS =====
    // Leitura: qualquer usuário autenticado pode verificar se um código existe
    // Escrita: NUNCA pelo cliente (apenas pelo backend via Service Account)
    match /codigos_promo/{code} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Nova coleção unificada (usada pelo proxy)
    match /promo_codes/{code} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ===== WEBHOOK EVENTS (idempotência) =====
    match /webhook_events/{id} {
      allow read, write: if false; // somente backend
    }

    // ===== CACHE / LOGS DE IA =====
    match /ia_cache/{hash} {
      allow read: if request.auth != null;
      allow write: if false; // somente backend
    }
    match /ia_logs/{logId} {
      allow read: if false; // somente admin
      allow write: if false;
    }

    // ===== RATE LIMITS =====
    match /rate_limits/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // somente backend
    }

    // ===== ADMIN CONFIG =====
    match /admin_config/{docId} {
      allow read, write: if false; // somente backend com Service Account
    }

    // ===== BLOQUEIA TUDO QUE NÃO FOI DECLARADO =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
